# ============================================================================
# ren.ai — environment configuration
# Copy to .env and fill in. EVERYTHING below is optional: with no values set,
# ren.ai runs fully in PAPER mode using REAL Bitget market prices + a built-in
# confluence rule engine, so judges can `npm run dev` with zero setup.
# ============================================================================

# ---- Core ----
PORT=8787                       # web + websocket + REST API port
TRADING_MODE=paper              # paper | demo | live
#   paper = internal simulator (real prices, simulated fills, NO keys needed)
#   demo  = Bitget Demo Trading via `bgc --paper-trading` (needs DEMO keys)
#   live  = real funds via `bgc` (needs LIVE keys w/ trade permission)

SYMBOLS=BTCUSDT,ETHUSDT         # perpetual symbols the agent watches
PRODUCT_TYPE=USDT-FUTURES
CANDLE_GRANULARITY=4H           # 4H — timeframe for the default Trend-Breakout strategy
LOOP_SECONDS=30                 # how often the agent perceives + decides
START_EQUITY=10000              # paper account starting equity (USDT)

# ---- MM30 strategy trigger (OPT-IN, off by default) ----
# 2-candle continuation pattern used as an entry TRIGGER, confirmed by the
# confluence lenses. NOTE: walk-forward testing showed the directional edge is
# unproven (see backtest_log.md) — keep this in PAPER mode and re-validate.
MM30_ENABLED=false              # master switch
MM30_RR=1                       # full take-profit at this R multiple
MM30_STOP_MODE=B                # B = stop just beyond candle B (the user spec)
MM30_MIN_RISK_PCT=0.5           # floor stop distance so fees can't exceed 1R
MM30_MAX_RISK_PCT=1.0           # skip the setup if candle B is too big
MM30_EMA_STACK=50               # trend gate: price>EMA20>EMA50 (held up out-of-sample)
MM30_VOL_FILTER=0               # volume>avg(N) filter — 0=off (overfit in tests)
MM30_STRONG_CLOSE=0             # strong-close conviction 0..1 — 0=off (overfit in tests)
MM30_REQUIRE_CONFLUENCE=true    # veto the trigger when the lenses oppose it

# ---- Trend-Breakout strategy (the agent's DEFAULT strategy — validated edge) ----
# EMA trend filter + breakout entry + chandelier trailing stop. Runs on 4H.
# Details: strategy_details.md · Backtest: node backend/src/backtest/runTrend.js --gran=4H
TREND_ENABLED=true              # master switch (ON by default; set false to fall back to confluence)
TREND_EMA_FAST=50               # fast EMA for the trend filter
TREND_EMA_SLOW=200              # slow EMA (needs CANDLE_LOOKBACK > this)
TREND_BREAKOUT_LEN=10           # enter on a break of the N-bar high/low
TREND_ATR_PERIOD=14
TREND_TRAIL_MULT=3              # initial stop & trailing distance = N × ATR
TREND_REQUIRE_CONFLUENCE=true   # veto a breakout when the lenses oppose it
CANDLE_LOOKBACK=400             # candles pulled per cycle (must exceed TREND_EMA_SLOW)

# ---- Agent brain (LLM) — OpenAI-compatible, with tool-calling for the skills.
#      Default: OpenRouter. Blank key -> transparent confluence rule engine. ----
LLM_PROVIDER=openrouter         # openrouter | qwen | openai | none
OPENROUTER_API_KEY=             # https://openrouter.ai/keys  (blank -> rule fallback)
LLM_MODEL=google/gemini-2.0-flash-001
# For Bitget Qwen credits instead:
#   LLM_PROVIDER=qwen
#   LLM_BASE_URL=https://hackathon.bitgetops.com/v1
#   LLM_MODEL=qwen3.6-plus
#   LLM_API_KEY=<your bitget qwen key>
LLM_BASE_URL=
LLM_API_KEY=

# ---- Bitget Agent Hub Skill Hub bridge ----
# When enabled, the five analyst lenses (technical / sentiment / macro /
# market-intel / news) pull LIVE reads from the Agent Hub skills; otherwise
# they degrade to derived/simulated reads so the loop always runs.
# The dashboard pill shows "live" only once real reads are flowing, "connecting"
# while enabled-but-not-yet-live, and "fallback" when off.
AGENT_HUB_ENABLED=true
# MCP transport — the Agent Hub server, spoken to over JSON-RPC/stdio.
# Needs the BITGET_* keys below (Read permission is enough for analyst skills).
AGENT_HUB_MCP_COMMAND=npx -y bitget-mcp-server
# Alternative transport: a custom bridge command run per read. Receives
# {skill,hub,symbol,snapshot} JSON on stdin, must print {score,summary} JSON on
# stdout (score in [-1,1]). When set, this takes priority over the MCP transport.
AGENT_HUB_COMMAND=

# ---- Confluence weights (need not sum to 1) ----
W_TECHNICAL=0.35
W_SENTIMENT=0.20
W_MACRO=0.15
W_MARKET_INTEL=0.15
W_NEWS=0.15

# ---- Bitget (agent's own account; only needed for demo/live mode) ----
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# ---- Telegram bot (the ONLY place users bind keys / configure copy-trade) ----
TELEGRAM_BOT_TOKEN=             # from @BotFather (blank -> bot disabled, web still works)
TELEGRAM_BOT_USERNAME=renai_tradingbot   # public handle the website CTA deep-links to (no @)

# ---- Security ----
# 32-byte key (hex) used to encrypt user API keys at rest. Auto-generated if blank.
SECRET_ENCRYPTION_KEY=
ADMIN_TOKEN=renai-admin         # token to access admin/control endpoints
