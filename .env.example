# ============================================================================
# ren.ai — environment configuration
# Copy to .env and fill in. EVERYTHING below is optional: with no values set,
# ren.ai runs fully in PAPER mode using REAL Bitget market prices + a built-in
# confluence rule engine, so judges can `npm run dev` with zero setup.
# ============================================================================

# ---- Core ----
PORT=8787                       # web + websocket + REST API port
TRADING_MODE=paper              # paper | demo | live
#   paper = internal simulator (real prices, simulated fills, NO keys needed)
#   demo  = Bitget Demo Trading via `bgc --paper-trading` (needs DEMO keys)
#   live  = real funds via `bgc` (needs LIVE keys w/ trade permission)

SYMBOLS=BTCUSDT,ETHUSDT         # perpetual symbols the agent watches
PRODUCT_TYPE=USDT-FUTURES
LOOP_SECONDS=30                 # how often the agent perceives + decides
START_EQUITY=10000              # paper account starting equity (USDT)

# ---- Agent brain (LLM) — OpenAI-compatible, with tool-calling for the skills.
#      Default: OpenRouter. Blank key -> transparent confluence rule engine. ----
LLM_PROVIDER=openrouter         # openrouter | qwen | openai | none
OPENROUTER_API_KEY=             # https://openrouter.ai/keys  (blank -> rule fallback)
LLM_MODEL=google/gemini-2.0-flash-001
# For Bitget Qwen credits instead:
#   LLM_PROVIDER=qwen
#   LLM_BASE_URL=https://hackathon.bitgetops.com/v1
#   LLM_MODEL=qwen3.6-plus
#   LLM_API_KEY=<your bitget qwen key>
LLM_BASE_URL=
LLM_API_KEY=

# ---- Bitget Agent Hub Skill Hub bridge ----
# When enabled, the five analyst lenses (technical / sentiment / macro /
# market-intel / news) pull LIVE reads from the Agent Hub skills; otherwise
# they degrade to derived/simulated reads so the loop always runs.
AGENT_HUB_ENABLED=false
AGENT_HUB_COMMAND=              # optional command/endpoint for the bridge

# ---- Confluence weights (need not sum to 1) ----
W_TECHNICAL=0.35
W_SENTIMENT=0.20
W_MACRO=0.15
W_MARKET_INTEL=0.15
W_NEWS=0.15

# ---- Bitget (agent's own account; only needed for demo/live mode) ----
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# ---- Telegram bot (the ONLY place users bind keys / configure copy-trade) ----
TELEGRAM_BOT_TOKEN=             # from @BotFather (blank -> bot disabled, web still works)
TELEGRAM_BOT_USERNAME=renai_trading_bot   # public handle the website CTA deep-links to (no @)

# ---- Security ----
# 32-byte key (hex) used to encrypt user API keys at rest. Auto-generated if blank.
SECRET_ENCRYPTION_KEY=
ADMIN_TOKEN=renai-admin         # token to access admin/control endpoints
